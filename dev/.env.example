# Python version to use for virtual environments
PYTHON_VERSION=3.11
# Network configuration for the Open WebUI backend
HOST=127.0.0.1
PORT=8080

# API key from Open WebUI (Settings -> Account)
API_KEY=sk-0000
# How often to poll for changes if file watcher misses something (seconds)
POLLING_INTERVAL=60

# Comma-separated absolute or relative paths to the function files
FILEPATHS="../gemini_manifold.py,../venice_manifold.py"
